<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wedding Wear Studio</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f8f8f8;
}

header{
    background:#7b112c;
    color:white;
    text-align:center;
    padding:25px;
}

header h1{
    font-size:40px;
}

header p{
    margin-top:10px;
}

.container{
    width:90%;
    margin:30px auto;
}

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:white;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 5px 15px rgba(0,0,0,0.15);
    transition:.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card img{
    width:100%;
    height:380px;
    object-fit:cover;
}

.card h3{
    padding:15px;
    text-align:center;
}

.btn{
    display:block;
    background:#25D366;
    color:white;
    text-decoration:none;
    text-align:center;
    padding:15px;
    font-weight:bold;
}

.btn:hover{
    background:#128C7E;
}

footer{
    margin-top:40px;
    background:#222;
    color:white;
    text-align:center;
    padding:20px;
}
</style>

</head>

<body>

<header>
<h1>Wedding Wear Studio</h1>
<p>Premium Wedding Wear Collection</p>
</header>

<div class="container">

<div class="products">

<div class="card">
<img src="https://via.placeholder.com/400x500?text=Bridal+Lehenga">
<h3>Bridal Lehenga WL001</h3>
